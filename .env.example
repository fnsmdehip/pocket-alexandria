# Pocket Alexandria Configuration
# Copy this to .env and fill in your values

# Web reader port (default: 8888)
PA_PORT=8888

# Debug mode for Flask (default: false)
PA_DEBUG=false

# Download settings
PA_DOWNLOAD_WORKERS=3
PA_REQUEST_DELAY=1.0

# Optional: API keys for AI-powered features
# Used for text classification in the discovery engine
# Supports DeepSeek or Gemini APIs
DEEPSEEK_API_KEY=
GEMINI_API_KEY=

# Content generation settings
PA_QUOTES_PER_BOOK=30
PA_MIN_VIRALITY_SCORE=25
